# ── Auth0 ─────────────────────────────────────────────────────────────────────
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_AUDIENCE=https://your-api-identifier

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./database.sqlite

# ── File uploads ──────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads

# ── Server ────────────────────────────────────────────────────────────────────
# Dev defaults: backend :3300, Flutter dev server :3000 — no changes needed.
# Prod: set these to your actual values.
BACKEND_HOST=0.0.0.0
BACKEND_PORT=3300

# ── CORS ──────────────────────────────────────────────────────────────────────
# Dev: Flutter dev server origin (port 3000)
# Prod: set to your deployed frontend URL, e.g. https://app.example.com
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
